# Polymarket Execution Engine - Environment Configuration
# Copy to .env and fill in your values
#
# NOTE: No Claude API key needed here!
# OpenClaw handles all Claude API calls. This engine is
# the "hands" — it executes commands from OpenClaw (the "brain").

# === Polymarket CLOB API ===
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_polymarket_profile_address
POLYMARKET_SIGNATURE_TYPE=1

# === Trading Config ===
INITIAL_CAPITAL=50.0
MAX_POSITION_SIZE=5.0
MAX_PORTFOLIO_RISK=0.06
DAILY_API_BUDGET=0.50
MIN_EDGE_THRESHOLD=0.08

# === API Server (Dashboard + Commands) ===
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3001

# === Database ===
DB_PATH=data/engine.db

# === Intervals ===
HEARTBEAT_INTERVAL_SECS=30
MARKET_SCAN_INTERVAL_SECS=300
POSITION_UPDATE_INTERVAL_SECS=60
